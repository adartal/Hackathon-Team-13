# URL of the deployed FastAPI backend (the server/ Vercel project).
# In local dev this defaults to http://localhost:8000 if unset.
VITE_API_URL=https://your-backend.vercel.app

# Nitro deploy preset. Defaults to "vercel" in vite.config.ts; set to
# "cloudflare" (or another Nitro preset) to build for a different target.
NITRO_PRESET=vercel
