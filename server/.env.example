# --- Gemini (AI engine) ---
# Free-tier key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key

# --- S3 / object storage ---
# Leave S3_ENDPOINT_URL empty to use AWS S3's default regional endpoint.
# For Cloudflare R2 or MinIO, set it to that service's S3 API endpoint, e.g.:
#   R2:    https://<accountid>.r2.cloudflarestorage.com
#   MinIO: http://localhost:9000
S3_ENDPOINT_URL=
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1
S3_DEFAULT_BUCKET=math-tutor-assets
